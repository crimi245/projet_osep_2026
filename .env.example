# Copie ce fichier en .env et remplis les valeurs manquantes
# cp .env.example .env

# ========================
# SERVEUR
# ========================
PORT=3000
APP_URL=http://localhost:3000

# ========================
# BASE DE DONNÉES PostgreSQL
# ========================
DB_USER=postgres
DB_HOST=localhost
DB_NAME=osep_db
DB_PASSWORD=
DB_PORT=5432

# ========================
# SÉCURITÉ
# ========================
# Génère une clé aléatoire longue, ex: openssl rand -base64 48
SESSION_SECRET=

# ========================
# ENVIRONNEMENT
# ========================
# Valeurs possibles: development | production
NODE_ENV=production
